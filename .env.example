# Backend REST API base URL — read by src/config/env.ts, used by src/api/client.ts.
# Local dev: point directly at the backend (avoids Vite proxy ambiguity).
# Production: set to your deployed API origin, e.g. https://api.example.com/api/v1
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Local dev proxy target (the running backend).
VITE_PROXY_TARGET=http://localhost:4000

# Public helpline number shown in header/footer (PRD risk-mitigation).
VITE_HELPLINE_NUMBER=1800-XXX-XXXX

# Grievance Officer details for the public footer (DPDP Act 2023 requirement).
VITE_GRIEVANCE_OFFICER_NAME=
VITE_GRIEVANCE_OFFICER_DESIGNATION=
VITE_GRIEVANCE_OFFICER_EMAIL=
VITE_GRIEVANCE_OFFICER_PHONE=

# Local dev defaults. Set VITE_USE_MOCKS=true to use in-browser mock backend.
# Currently pointing at Vercel backend for live testing.
VITE_USE_MOCKS=false

# Backend on Vercel — update if URL changes after redeployment
VITE_API_BASE_URL=https://alwar-rojgar-setu-backend.vercel.app/api/v1

# Vite proxy fallback (only used if VITE_API_BASE_URL is unset / uses relative path)
VITE_PROXY_TARGET=http://localhost:4000
